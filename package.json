*{box-sizing:border-box}body{margin:0;font-family:Inter,Arial,sans-serif;background:#f5f7fb;color:#101828}.app{display:flex;min-height:100vh}.sidebar{width:260px;background:linear-gradient(180deg,#071d3a,#031021);color:white;padding:24px 18px;display:flex;flex-direction:column;gap:24px}.brand{display:flex;gap:12px;align-items:center;font-size:22px;letter-spacing:2px}.brand span{display:block;font-size:16px;letter-spacing:5px}.logo{width:48px;height:48px;background:#1473e6;border-radius:14px;display:grid;place-items:center;font-size:26px}nav{display:flex;flex-direction:column;gap:8px}nav a{padding:14px 14px;border-radius:10px;color:#dbeafe;text-decoration:none;cursor:pointer}.active,nav a:hover{background:#1268df}.upgrade{margin-top:auto;border:1px solid rgba(255,255,255,.18);border-radius:16px;padding:18px;text-align:center;background:rgba(255,255,255,.04)}.upgrade p{font-size:13px;color:#cbd5e1}.upgrade button,.card button,.primary{background:#1268df;color:white;border:0;border-radius:8px;padding:11px 16px;font-weight:700;cursor:pointer}.circle{margin:auto;background:#1473e6;width:44px;height:44px;border-radius:50%;display:grid;place-items:center}.profile{display:flex;align-items:center;gap:12px;background:rgba(255,255,255,.08);padding:12px;border-radius:14px}.profile span{display:block;color:#cbd5e1;font-size:13px}.avatar,.small-avatar{background:#d8e9ff;color:#0f3b79;border-radius:50%;font-weight:800;display:grid;place-items:center}.avatar{width:42px;height:42px}.small-avatar{width:38px;height:38px}.main{flex:1;padding:26px;overflow:auto}header{display:flex;justify-content:space-between;align-items:center;margin-bottom:24px}h1{font-size:26px;margin:0}.top-actions{display:flex;gap:16px;align-items:center}.bell{font-size:24px}.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;margin-bottom:22px}.stat,.card{background:white;border:1px solid #e6ebf2;border-radius:16px;box-shadow:0 8px 26px rgba(16,24,40,.06)}.stat{padding:22px;display:flex;gap:16px;align-items:center}.stat-icon{width:58px;height:58px;border-radius:50%;background:#eef4ff;display:grid;place-items:center;font-size:26px}.stat span{display:block;color:#667085;font-size:13px}.stat strong{display:block;font-size:22px;margin:6px 0}.stat a,.link{color:#1268df;font-weight:700;font-size:13px}.grid{display:grid;gap:22px;margin-bottom:22px}.two{grid-template-columns:2fr 1fr}.dashboard-grid{grid-template-columns:1fr 2fr}.card{padding:22px}.card-title{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px}.card h2{margin:0;font-size:20px}.steps{display:flex;justify-content:space-between;gap:10px}.step{text-align:center;flex:1;position:relative}.step div{margin:auto;width:44px;height:44px;border-radius:50%;background:#e5e7eb;display:grid;place-items:center;font-weight:800}.step.done div{background:#16a34a;color:white}.step.current div{background:#1268df;color:white}.step strong{display:block;margin-top:10px;font-size:14px}.step span{font-size:13px;color:#667085}.form{display:flex;flex-direction:column;gap:10px}input,textarea{border:1px solid #d0d5dd;border-radius:10px;padding:12px;font:inherit;background:white}textarea{min-height:92px;resize:vertical}.check{background:#f8fafc!important;color:#334155!important;text-align:left;border:1px solid #e2e8f0!important}.check.checked{background:#ecfdf3!important;color:#027a48!important}.table{border-top:1px solid #e6ebf2}.row{display:grid;grid-template-columns:1.4fr 1fr 1fr 1fr auto;gap:12px;align-items:center;padding:14px;border-bottom:1px solid #e6ebf2;cursor:pointer}.row.selected{background:#f0f7ff}.row small{display:block;color:#667085;margin-top:3px}.row.head{font-size:12px;text-transform:uppercase;color:#667085;font-weight:700;cursor:default}.row em{font-style:normal;background:#e8f1ff;color:#1268df;padding:6px 9px;border-radius:8px;font-size:12px}.row button{background:#f04438!important;padding:8px 10px!important}.payment{display:flex;flex-direction:column;gap:10px}.payment strong{font-size:32px;color:#1268df}.letter{min-height:360px;font-family:ui-monospace,SFMono-Regular,Menlo,monospace;font-size:13px}.review-buttons{display:flex;gap:10px;flex-wrap:wrap;margin:14px 0}.review-buttons button:nth-child(2){background:#475467}.review-buttons button:nth-child(3){background:#d92d20}.warning{background:#fff7ed;border:1px solid #fed7aa;color:#9a3412;border-radius:12px;padding:14px;font-size:14px}@media(max-width:1000px){.app{flex-direction:column}.sidebar{width:100%}.stats,.two,.dashboard-grid{grid-template-columns:1fr}.row{grid-template-columns:1fr}.steps{flex-direction:column;text-align:left}.step{text-align:left}.step div{margin:0}}
